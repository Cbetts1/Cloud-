# Required — change these before deploying!
JWT_SECRET=change-this-to-a-long-random-secret

# Optional
PORT=3000
JWT_EXPIRES_IN=7d

# Storage directory (relative to project root)
STORAGE_DIR=storage

# Data directory for the JSON database
DATA_DIR=data

# Max upload size in MB (default 100)
MAX_FILE_SIZE_MB=100

# CORS origin — for remote access from phone/other repos set this to * or comma-separated allowed origins
# e.g. CORS_ORIGIN=* or CORS_ORIGIN=https://your-app.railway.app,https://myphone.app
# Leave unset to restrict to same-origin only (safe default for production with a frontend on the same server)
CORS_ORIGIN=*
