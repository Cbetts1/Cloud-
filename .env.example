# Required — change these before deploying!
JWT_SECRET=change-this-to-a-long-random-secret

# Optional
PORT=3000
JWT_EXPIRES_IN=7d

# Storage directory (relative to project root)
STORAGE_DIR=storage

# Data directory for the JSON database
DATA_DIR=data

# Max upload size in MB (default 100)
MAX_FILE_SIZE_MB=100

# CORS origin — set to your frontend URL in production, or leave * for open access
# CORS_ORIGIN=https://your-app.railway.app
